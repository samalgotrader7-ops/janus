# Janus environment — copy to `.env` (gitignored) and edit.
# Janus loads `.env` from the current working directory at startup, then
# falls back to `~/.janus/.env`. Existing shell exports always win.
#
# Provider key (REQUIRED). Default JANUS_API_BASE points at OpenRouter.
JANUS_API_KEY=sk-or-v1-replace-me

# Pick a model. Some good defaults:
#   anthropic/claude-sonnet-4-6     (smart, vision-capable)
#   openai/gpt-4o-mini              (cheap, fast)
#   anthropic/claude-haiku-4-5      (cheapest, fastest)
JANUS_MODEL=anthropic/claude-sonnet-4-6

# Override the API base for direct providers (uncomment as needed).
# Any OpenAI-compatible endpoint works:
#   https://openrouter.ai/api/v1     (default — 200+ models, cache_control honored)
#   https://api.openai.com/v1
#   http://localhost:11434/v1        (Ollama — local, free, set MODEL e.g. local/llama)
#   http://localhost:8080/v1         (LM Studio, llama.cpp, vLLM, etc.)
JANUS_API_BASE=https://openrouter.ai/api/v1

# Phase 20: when on, llm.chat wraps the system message with Anthropic-style
# cache_control: ephemeral markers. OpenRouter forwards this to Anthropic's
# prompt cache; OpenAI ignores extra fields. Worth turning on if you route
# Claude models through OpenRouter and have long system prompts.
# JANUS_PROMPT_CACHE=1

# Where Janus reads/writes files via fs/shell tools (defaults to cwd).
# Useful to pin to a project root so commands don't escape on accident.
# JANUS_WORKSPACE=/abs/path/to/project

# Optional: cheaper model for the memory propose-diff loop (Phase 2).
# JANUS_MEMORY_MODEL=openai/gpt-4o-mini

# Optional: web search (Phase 9). Free key at https://api.search.brave.com/
# JANUS_BRAVE_API_KEY=

# Optional: telegram gateway.
# JANUS_TELEGRAM_TOKEN=
# JANUS_TELEGRAM_CHATS=11111111,22222222

# Optional: WhatsApp Cloud API gateway (Phase 11).
# JANUS_WHATSAPP_TOKEN=
# JANUS_WHATSAPP_PHONE_ID=
# JANUS_WHATSAPP_VERIFY=some-string-you-pick
# JANUS_WHATSAPP_ALLOWED=15551234567,15557654321
